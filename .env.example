# Copy to .env.local and fill in. Set the same vars in Vercel → Settings → Environment Variables.

# Orthogonal API key — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
ORTHOGONAL_API_KEY=

# Daily spending cap in USD (hard ceiling across all visitors). Integer, e.g. 40.
DAILY_SPEND_CAP_USD=40

# Secret used to sign request/timing tokens. Random 32+ char string.
REQUEST_TOKEN_SECRET=

# Public deployment origin (used for same-origin checks on API routes).
# e.g. https://your-app.vercel.app  — in local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# OPTIONAL — Supabase for a shared, persistent spend cap + rate limiter
# (Level 2). Leave blank to use the in-memory per-instance counters. When set,
# the $40 cap and per-visitor limits hold across all serverless instances.
# Run supabase/migrations/0001_jobsitev2_spend_and_rate_limit.sql first. Free tier is fine.
# SERVICE ROLE key is server-side only — never expose it / never NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
